---
import { articleSections, articles } from "../data/articles";

const base = import.meta.env.BASE_URL;
const highlights = [
	{
		label: "村庄档案",
		text: "村名、方位、旧地名和重要地点，先搭出写作的骨架。",
	},
	{
		label: "旧街旧物",
		text: "老宅、院落、街巷和公共空间，记录村里还能被看见的痕迹。",
	},
	{
		label: "人和日子",
		text: "长辈、邻里、农事和节令，把游殿村写成一个有生活气息的地方。",
	},
];
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta
			name="description"
			content="一个从游殿村开始的乡村故事项目，整理村庄记忆、旧街旧物和日常生活。"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>游殿村故事</title>
	</head>
	<body>
		<main class="site-shell">
			<nav class="site-nav" aria-label="主导航">
				<a class="brand" href={base}>游殿村故事</a>
				<div class="nav-links">
					<a href="#catalog">首页目录</a>
					<a href={`${base}articles/`}>文章目录</a>
				</div>
			</nav>

			<section class="hero" aria-labelledby="hero-title">
				<div class="hero__copy">
					<p class="eyebrow">Youdian Village Stories</p>
					<h1 id="hero-title">我住在游殿村，想把这里慢慢写下来</h1>
					<p class="intro">
						这个站点会收集关于游殿村的故事：村名的来处、街巷和老房子、
						家人邻里的记忆，还有一年四季里的日常生活。
					</p>
					<div class="hero-actions">
						<a class="button" href={`${base}articles/`}>查看文章目录</a>
						<a class="button button--ghost" href="#catalog">浏览写作结构</a>
					</div>
				</div>
				<div class="hero__panel" aria-label="项目概览">
					<span class="panel-kicker">项目结构</span>
					<strong>{articleSections.length} 个栏目</strong>
					<span>{articles.length} 篇占位文章</span>
				</div>
			</section>

			<section class="highlights" aria-label="首页结构">
				{highlights.map((item) => (
					<article class="highlight-card">
						<span>{item.label}</span>
						<p>{item.text}</p>
					</article>
				))}
			</section>

			<section class="catalog" id="catalog" aria-labelledby="catalog-title">
				<div class="section-heading">
					<p class="eyebrow">Directory</p>
					<h2 id="catalog-title">故事目录结构</h2>
					<p>
						先用栏目搭起写作框架，后续可以把采访、资料和回忆逐篇补进来。
					</p>
				</div>

				<div class="section-list">
					{articleSections.map((section) => (
						<section class="directory-section" aria-labelledby={`section-${section.title}`}>
							<div>
								<h3 id={`section-${section.title}`}>{section.title}</h3>
								<p>{section.description}</p>
							</div>
							<div class="article-grid">
								{section.articles.map((article) => (
									<a class="article-card" href={`${base}${article.href}`}>
										<span class="article-card__label">{article.category}</span>
										<strong>{article.title}</strong>
										<small>{article.description}</small>
										<em>{article.status}</em>
									</a>
								))}
							</div>
						</section>
					))}
				</div>
			</section>
		</main>
	</body>
</html>

<style>
	:root {
		color: #172033;
		background: #f8f2e8;
		font-family:
			Inter, "Noto Sans SC", "PingFang SC", "Microsoft YaHei", system-ui,
			sans-serif;
	}

	body {
		margin: 0;
		min-height: 100vh;
		background:
			radial-gradient(circle at top left, rgba(214, 158, 46, 0.18), transparent 32rem),
			radial-gradient(circle at 85% 10%, rgba(96, 165, 250, 0.22), transparent 28rem),
			linear-gradient(135deg, #fffaf0 0%, #eef4ff 100%);
	}

	.site-shell {
		box-sizing: border-box;
		width: min(100%, 74rem);
		margin: 0 auto;
		padding: 2rem 1.25rem 5rem;
	}

	.site-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 4rem;
	}

	.brand,
	.nav-links a {
		color: inherit;
		font-weight: 700;
		text-decoration: none;
	}

	.brand {
		font-size: 1.05rem;
	}

	.nav-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		color: #465367;
		font-size: 0.95rem;
	}

	.nav-links a:hover,
	.nav-links a:focus-visible {
		color: #b45309;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(16rem, 24rem);
		align-items: end;
		gap: clamp(2rem, 6vw, 5rem);
		padding-bottom: 4rem;
	}

	.eyebrow {
		margin: 0 0 1rem;
		color: #b45309;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		max-width: 12ch;
		font-size: clamp(2.7rem, 8vw, 5.8rem);
		line-height: 1.05;
	}

	.intro {
		margin: 1.5rem 0 2rem;
		max-width: 38rem;
		color: #465367;
		font-size: 1.15rem;
		line-height: 1.8;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.8rem;
		padding: 0 1.1rem;
		border: 1px solid #172033;
		border-radius: 999px;
		background: #172033;
		color: #fffaf0;
		font-weight: 700;
		text-decoration: none;
	}

	.button--ghost {
		background: rgba(255, 255, 255, 0.56);
		color: #172033;
	}

	.hero__panel {
		display: grid;
		gap: 0.65rem;
		padding: 1.5rem;
		border: 1px solid rgba(23, 32, 51, 0.12);
		border-radius: 1.5rem;
		background: rgba(255, 255, 255, 0.7);
		box-shadow: 0 1rem 3rem rgba(23, 32, 51, 0.08);
	}

	.hero__panel strong {
		font-size: clamp(2rem, 5vw, 3.5rem);
		line-height: 1;
	}

	.panel-kicker,
	.article-card__label,
	.highlight-card span {
		color: #b45309;
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.highlights {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 4rem;
	}

	.highlight-card,
	.article-card {
		display: grid;
		gap: 0.75rem;
		padding: 1.25rem;
		border: 1px solid rgba(23, 32, 51, 0.12);
		border-radius: 1.25rem;
		background: rgba(255, 255, 255, 0.72);
		box-shadow: 0 1rem 3rem rgba(23, 32, 51, 0.08);
	}

	.highlight-card p {
		margin: 0;
		color: #465367;
		line-height: 1.75;
	}

	.catalog {
		display: grid;
		gap: 2rem;
	}

	.section-heading {
		max-width: 42rem;
	}

	h2 {
		margin: 0;
		font-size: clamp(2rem, 5vw, 3.2rem);
		line-height: 1.1;
	}

	.section-heading p,
	.directory-section > div > p {
		color: #465367;
		line-height: 1.8;
	}

	.section-list {
		display: grid;
		gap: 1.25rem;
	}

	.directory-section {
		display: grid;
		grid-template-columns: minmax(12rem, 18rem) 1fr;
		gap: 1.25rem;
		padding: 1.25rem;
		border: 1px solid rgba(23, 32, 51, 0.1);
		border-radius: 1.5rem;
		background: rgba(255, 255, 255, 0.48);
	}

	h3 {
		margin: 0;
		font-size: 1.35rem;
	}

	.article-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.article-card {
		color: inherit;
		text-decoration: none;
		transition:
			transform 160ms ease,
			box-shadow 160ms ease;
	}

	.article-card:hover,
	.article-card:focus-visible {
		transform: translateY(-0.15rem);
		box-shadow: 0 1.25rem 3rem rgba(23, 32, 51, 0.14);
	}

	.article-card strong {
		font-size: 1.25rem;
	}

	.article-card small {
		color: #465367;
		font-size: 0.95rem;
		line-height: 1.65;
	}

	.article-card em {
		width: fit-content;
		padding: 0.25rem 0.6rem;
		border-radius: 999px;
		background: #fff7ed;
		color: #9a3412;
		font-size: 0.8rem;
		font-style: normal;
		font-weight: 700;
	}

	@media (max-width: 760px) {
		.site-nav,
		.hero,
		.directory-section {
			grid-template-columns: 1fr;
		}

		.site-nav {
			align-items: flex-start;
		}

		.highlights,
		.article-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
