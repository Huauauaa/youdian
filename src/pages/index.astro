---
import { articleSections, articles } from "../data/articles";
import "../styles/global.css";

const base = import.meta.env.BASE_URL;
const pageBackgroundClass =
	"min-h-screen bg-[radial-gradient(circle_at_top_left,rgba(66,184,131,0.16),transparent_30rem),radial-gradient(circle_at_top_right,rgba(180,83,9,0.09),transparent_28rem),linear-gradient(180deg,#fffaf0_0%,#f8f1e3_100%)] font-sans text-youdian-ink";
const eyebrowClass =
	"mb-4 text-[0.78rem] font-extrabold uppercase tracking-[0.2em] text-youdian-leaf-dark";
const kickerClass =
	"text-[0.78rem] font-extrabold uppercase tracking-[0.14em] text-youdian-leaf-dark";
const glassCardClass =
	"glass-card grid gap-3 rounded-[1.35rem] p-5";
const articleCardClass =
	`${glassCardClass} text-inherit no-underline`;
const publishedArticles = articles.filter((article) => article.status === "已发布");
const featuredArticles = publishedArticles.length > 0 ? publishedArticles : articles.slice(0, 2);
const primaryArticle = featuredArticles[0];
const featureCards = [
	{
		label: "Story",
		title: "从一篇真实故事开始",
		description: primaryArticle.description,
		href: `${base}${primaryArticle.href}`,
	},
	{
		label: "Directory",
		title: "只保留已写好的文章",
		description: `${articleSections.length} 个栏目，${articles.length} 篇已整理文章，目录保持清楚克制。`,
		href: `${base}articles/`,
	},
	{
		label: "Interactive",
		title: "用互动卡片整理线索",
		description: "像文档站的演示区一样，把村庄主题和日常片段做成可点选的轻量页面。",
		href: `${base}react/`,
	},
];
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta
			name="description"
			content="一个从游殿村开始的乡村故事项目，整理村庄记忆、旧街旧物和日常生活。"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>游殿村故事</title>
	</head>
	<body class={pageBackgroundClass}>
		<main class="mx-auto box-border w-full max-w-[68rem] px-5 pt-5 pb-16">
			<nav
				class="mb-12 flex flex-col items-start justify-between gap-4 border-b border-youdian-ink/10 py-4 sm:flex-row sm:items-center"
				aria-label="主导航"
			>
				<a class="inline-flex items-center gap-2 text-[1.05rem] font-extrabold tracking-[-0.01em] text-inherit no-underline" href={base}>
					<span class="h-3 w-3 rounded-full bg-youdian-leaf shadow-[0_0_0_0.35rem_rgba(66,184,131,0.14)]"></span>
					游殿村故事
				</a>
				<div class="flex flex-wrap gap-5 text-[0.95rem] text-youdian-muted">
					<a
						class="font-bold text-inherit no-underline transition hover:text-youdian-leaf-dark focus-visible:text-youdian-leaf-dark"
						href={`${base}articles/`}
					>
						文章目录
					</a>
					<a
						class="font-bold text-inherit no-underline transition hover:text-youdian-leaf-dark focus-visible:text-youdian-leaf-dark"
						href={`${base}react/`}
					>
						React 互动页
					</a>
				</div>
			</nav>

			<section
				class="mx-auto grid max-w-[52rem] justify-items-center text-center"
				aria-labelledby="hero-title"
			>
				<p class={eyebrowClass}>Youdian Village Stories</p>
				<h1 id="hero-title" class="m-0 max-w-[14ch] text-[clamp(2.8rem,9vw,5.8rem)] font-extrabold leading-[1.02] tracking-[-0.06em]">
					把游殿村的故事慢慢写下来
				</h1>
				<p class="my-6 max-w-[38rem] text-[1.12rem] leading-[1.8] text-youdian-muted">
					页面只保留最重要的入口：读故事、看目录、试试互动页。
				</p>
				<div class="flex flex-wrap justify-center gap-3">
					<a
						class="inline-flex min-h-11 items-center justify-center rounded-full bg-youdian-leaf px-[1.2rem] font-bold text-white no-underline shadow-[0_0.75rem_1.8rem_rgba(66,184,131,0.22)] transition hover:-translate-y-0.5 hover:bg-youdian-leaf-dark focus-visible:-translate-y-0.5"
						href={`${base}${primaryArticle.href}`}
					>
						开始阅读
					</a>
					<a
						class="inline-flex min-h-11 items-center justify-center rounded-full border border-youdian-ink/12 bg-white/75 px-[1.2rem] font-bold text-youdian-ink no-underline transition hover:-translate-y-0.5 hover:border-youdian-leaf focus-visible:-translate-y-0.5"
						href={`${base}articles/`}
					>
						文章目录
					</a>
				</div>
			</section>

			<section class="grid gap-4 pt-14 md:grid-cols-3" aria-label="页面入口">
				{featureCards.map((card) => (
					<a class={articleCardClass} href={card.href}>
						<div class="grid gap-4">
							<div class="flex items-center justify-between gap-3">
								<span class={kickerClass}>{card.label}</span>
								<span class="grid h-8 w-8 place-items-center rounded-full bg-youdian-mint text-youdian-leaf-dark">→</span>
							</div>
							<strong class="text-[1.25rem] leading-[1.25]">{card.title}</strong>
							<small class="text-[0.95rem] leading-[1.65] text-youdian-muted">
								{card.description}
							</small>
						</div>
					</a>
				))}
			</section>
		</main>
	</body>
</html>
