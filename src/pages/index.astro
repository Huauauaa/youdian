---
import { articleSections, articles } from "../data/articles";
import "../styles/global.css";

const base = import.meta.env.BASE_URL;
const pageBackgroundClass =
	"min-h-screen bg-[radial-gradient(circle_at_top_left,rgba(214,158,46,0.12),transparent_36rem),linear-gradient(180deg,#fffaf0_0%,#f8f1e3_100%)] font-sans text-youdian-ink";
const eyebrowClass =
	"mb-4 text-[0.78rem] font-extrabold uppercase tracking-[0.2em] text-youdian-accent";
const kickerClass =
	"text-[0.78rem] font-extrabold uppercase tracking-[0.14em] text-youdian-accent";
const glassCardClass =
	"glass-card grid gap-3 rounded-[1.25rem] p-5";
const articleCardClass =
	`${glassCardClass} text-inherit no-underline hover:-translate-y-0.5 focus-visible:-translate-y-0.5`;
const highlights = [
	{
		label: "村庄档案",
		text: "村名、方位、旧地名和重要地点，先搭出写作的骨架。",
	},
	{
		label: "旧街旧物",
		text: "老宅、院落、街巷和公共空间，记录村里还能被看见的痕迹。",
	},
	{
		label: "人和日子",
		text: "长辈、邻里、农事和节令，把游殿村写成一个有生活气息的地方。",
	},
];
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta
			name="description"
			content="一个从游殿村开始的乡村故事项目，整理村庄记忆、旧街旧物和日常生活。"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>游殿村故事</title>
	</head>
	<body class={pageBackgroundClass}>
		<main class="mx-auto box-border w-full max-w-[74rem] px-5 pt-8 pb-20">
			<nav
				class="mb-16 flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center"
				aria-label="主导航"
			>
				<a class="text-[1.05rem] font-bold text-inherit no-underline" href={base}>游殿村故事</a>
				<div class="flex flex-wrap gap-[0.9rem] text-[0.95rem] text-youdian-muted">
					<a
						class="font-bold text-inherit no-underline hover:text-youdian-accent focus-visible:text-youdian-accent"
						href="#catalog"
					>
						首页目录
					</a>
					<a
						class="font-bold text-inherit no-underline hover:text-youdian-accent focus-visible:text-youdian-accent"
						href={`${base}articles/`}
					>
						文章目录
					</a>
				</div>
			</nav>

			<section
				class="grid items-end gap-[clamp(2rem,6vw,5rem)] pb-16 md:grid-cols-[minmax(0,1fr)_minmax(16rem,24rem)]"
				aria-labelledby="hero-title"
			>
				<div>
					<p class={eyebrowClass}>Youdian Village Stories</p>
					<h1 id="hero-title" class="m-0 max-w-[12ch] text-[clamp(2.7rem,8vw,5.8rem)] leading-[1.05]">
						我住在游殿村，想把这里慢慢写下来
					</h1>
					<p class="my-6 max-w-[38rem] text-[1.15rem] leading-[1.8] text-youdian-muted">
						这个站点会收集关于游殿村的故事：村名的来处、街巷和老房子、
						家人邻里的记忆，还有一年四季里的日常生活。
					</p>
					<div class="flex flex-wrap gap-[0.85rem]">
						<a
							class="inline-flex min-h-11 items-center justify-center rounded-full border border-youdian-ink bg-youdian-ink px-[1.1rem] font-bold text-youdian-paper no-underline"
							href={`${base}articles/`}
						>
							查看文章目录
						</a>
						<a
							class="inline-flex min-h-11 items-center justify-center rounded-full border border-youdian-ink bg-white/55 px-[1.1rem] font-bold text-youdian-ink no-underline"
							href="#catalog"
						>
							浏览写作结构
						</a>
					</div>
				</div>
				<div
					class="grid gap-[0.65rem] rounded-3xl border border-youdian-ink/10 bg-white/70 p-6 shadow-[0_1rem_3rem_rgba(23,32,51,0.08)]"
					aria-label="项目概览"
				>
					<span class={kickerClass}>项目结构</span>
					<strong class="text-[clamp(2rem,5vw,3.5rem)] leading-none">{articleSections.length} 个栏目</strong>
					<span>{articles.length} 篇占位文章</span>
				</div>
			</section>

			<section class="mb-16 grid gap-4 md:grid-cols-3" aria-label="首页结构">
				{highlights.map((item) => (
					<article class={glassCardClass}>
						<span class={kickerClass}>{item.label}</span>
						<p class="m-0 leading-[1.75] text-youdian-muted">{item.text}</p>
					</article>
				))}
			</section>

			<section class="grid gap-8" id="catalog" aria-labelledby="catalog-title">
				<div class="max-w-[42rem]">
					<p class={eyebrowClass}>Directory</p>
					<h2 id="catalog-title" class="m-0 text-[clamp(2rem,5vw,3.2rem)] leading-[1.1]">
						故事目录结构
					</h2>
					<p class="leading-[1.8] text-youdian-muted">
						先用栏目搭起写作框架，后续可以把采访、资料和回忆逐篇补进来。
					</p>
				</div>

				<div class="grid gap-5">
					{articleSections.map((section) => (
						<section
							class="grid gap-5 rounded-3xl border border-youdian-ink/10 bg-white/50 p-5 md:grid-cols-[minmax(12rem,18rem)_1fr]"
							aria-labelledby={`section-${section.title}`}
						>
							<div>
								<h3 id={`section-${section.title}`} class="m-0 text-[1.35rem]">
									{section.title}
								</h3>
								<p class="leading-[1.8] text-youdian-muted">{section.description}</p>
							</div>
							<div class="grid gap-4 lg:grid-cols-2">
								{section.articles.map((article) => (
									<a class={articleCardClass} href={`${base}${article.href}`}>
										<span class={kickerClass}>{article.category}</span>
										<strong class="text-xl">{article.title}</strong>
										<small class="text-[0.95rem] leading-[1.65] text-youdian-muted">
											{article.description}
										</small>
										<em class="status-badge not-italic">
											{article.status}
										</em>
									</a>
								))}
							</div>
						</section>
					))}
				</div>
			</section>
		</main>
	</body>
</html>
