---
import { articleSections, articles } from "../../data/articles";
import "../../styles/global.css";

const base = import.meta.env.BASE_URL;
const pageBackgroundClass =
	"min-h-screen bg-[radial-gradient(circle_at_top_left,rgba(214,158,46,0.16),transparent_30rem),linear-gradient(180deg,#fffaf0_0%,#f8fafc_100%)] font-sans text-youdian-ink";
const eyebrowClass =
	"mb-4 text-[0.82rem] font-extrabold uppercase tracking-[0.12em] text-youdian-accent";
const articleCardClass =
	"grid gap-[0.7rem] rounded-[1.2rem] border border-youdian-ink/10 bg-white/80 p-[1.2rem] text-inherit no-underline transition duration-150 ease-out hover:-translate-y-0.5 hover:shadow-[0_1.25rem_3rem_rgba(23,32,51,0.14)] focus-visible:-translate-y-0.5 focus-visible:shadow-[0_1.25rem_3rem_rgba(23,32,51,0.14)]";
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<link rel="icon" href={`${base}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta
			name="description"
			content="游殿村故事的文章目录，按村庄档案、老房子与旧街、人和日子整理。"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>文章目录 | 游殿村故事</title>
	</head>
	<body class={pageBackgroundClass}>
		<main class="mx-auto box-border w-full max-w-[68rem] px-5 pt-12 pb-20">
			<nav
				class="mb-16 flex flex-wrap items-center justify-between gap-4"
				aria-label="目录导航"
			>
				<a
					class="font-bold text-youdian-accent no-underline hover:underline focus-visible:underline"
					href={base}
				>
					← 返回首页
				</a>
				<span class="font-bold text-gray-500">{articles.length} 篇文章</span>
			</nav>

			<header class="mb-12 max-w-[48rem]">
				<p class={eyebrowClass}>Article Directory</p>
				<h1 class="m-0 text-[clamp(2.5rem,8vw,5rem)] leading-[1.1]">游殿村故事目录</h1>
				<p class="text-[1.05rem] leading-[1.8] text-youdian-muted">
					这些文章先用标题和简介占位，方便后续把采访、资料、回忆和照片逐步填进来。
				</p>
			</header>

			<div class="grid gap-5">
				{articleSections.map((section) => (
					<section
						class="grid gap-5 rounded-3xl border border-youdian-ink/10 bg-white/60 p-5 shadow-[0_1rem_3rem_rgba(23,32,51,0.06)] md:grid-cols-[minmax(12rem,18rem)_1fr]"
						aria-labelledby={`catalog-${section.title}`}
					>
						<div>
							<h2 id={`catalog-${section.title}`} class="m-0 text-2xl leading-[1.1]">
								{section.title}
							</h2>
							<p class="text-[1.05rem] leading-[1.8] text-youdian-muted">
								{section.description}
							</p>
						</div>
						<div class="grid gap-4 lg:grid-cols-2">
							{section.articles.map((article) => (
								<a class={articleCardClass} href={`${base}${article.href}`}>
									<span class={`${eyebrowClass} m-0`}>{article.category}</span>
									<strong class="text-[1.2rem]">{article.title}</strong>
									<small class="text-[0.95rem] leading-[1.65] text-youdian-muted">
										{article.description}
									</small>
									<em class="w-fit rounded-full bg-orange-50 px-2.5 py-1 text-[0.8rem] font-bold not-italic text-youdian-rust">
										{article.status}
									</em>
								</a>
							))}
						</div>
					</section>
				))}
			</div>
		</main>
	</body>
</html>
