---
import { articleSections, articles } from "../../data/articles";
import "../../styles/global.css";

const base = import.meta.env.BASE_URL;
const pageBackgroundClass =
	"min-h-screen bg-[radial-gradient(circle_at_top_left,rgba(66,184,131,0.14),transparent_30rem),linear-gradient(180deg,#fffaf0_0%,#f8f1e3_100%)] font-sans text-youdian-ink";
const eyebrowClass =
	"mb-4 text-[0.78rem] font-extrabold uppercase tracking-[0.2em] text-youdian-leaf-dark";
const articleCardClass =
	"glass-card grid gap-[0.8rem] rounded-[1.4rem] p-5 text-inherit no-underline";
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<link rel="icon" href={`${base}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta
			name="description"
			content="游殿村故事的文章目录，整理已经写好的村庄故事。"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>文章目录 | 游殿村故事</title>
	</head>
	<body class={pageBackgroundClass}>
		<main class="mx-auto box-border w-full max-w-[64rem] px-5 pt-5 pb-16">
			<nav
				class="mb-12 flex flex-wrap items-center justify-between gap-4 border-b border-youdian-ink/10 py-4"
				aria-label="目录导航"
			>
				<a
					class="font-bold text-youdian-leaf-dark no-underline transition hover:text-youdian-ink focus-visible:text-youdian-ink"
					href={base}
				>
					← 返回首页
				</a>
				<span class="rounded-full bg-youdian-mint px-3 py-1 text-sm font-bold text-youdian-leaf-dark">{articles.length} 篇文章</span>
			</nav>

			<header class="mx-auto mb-12 grid max-w-[46rem] justify-items-center text-center">
				<p class={eyebrowClass}>Article Directory</p>
				<h1 class="m-0 text-[clamp(2.4rem,8vw,4.8rem)] font-extrabold leading-[1.04] tracking-[-0.05em]">游殿村故事目录</h1>
				<p class="max-w-[34rem] text-[1.05rem] leading-[1.8] text-youdian-muted">
					这里只放已经写好的文章。列表保持克制，方便直接进入阅读。
				</p>
			</header>

			<div class="grid gap-4">
				{articleSections.map((section) => (
					<section
						class="grid gap-5 rounded-[1.6rem] border border-youdian-ink/10 bg-white/60 p-5 shadow-[0_1rem_3rem_rgba(23,32,51,0.06)] md:grid-cols-[minmax(10rem,15rem)_1fr]"
						aria-labelledby={`catalog-${section.title}`}
					>
						<div>
							<h2 id={`catalog-${section.title}`} class="m-0 text-2xl leading-[1.1]">
								{section.title}
							</h2>
							<p class="text-[1.05rem] leading-[1.8] text-youdian-muted">
								{section.description}
							</p>
						</div>
						<div class="grid gap-4 lg:grid-cols-2">
							{section.articles.map((article) => (
								<a class={articleCardClass} href={`${base}${article.href}`}>
									<div class="flex items-center justify-between gap-3">
										<span class={`${eyebrowClass} m-0`}>{article.category}</span>
										<span class="grid h-8 w-8 place-items-center rounded-full bg-youdian-mint text-youdian-leaf-dark">→</span>
									</div>
									<strong class="text-[1.25rem] leading-[1.25]">{article.title}</strong>
									<small class="text-[0.95rem] leading-[1.65] text-youdian-muted">
										{article.description}
									</small>
									<em class="status-badge not-italic">
										{article.status}
									</em>
								</a>
							))}
						</div>
					</section>
				))}
			</div>
		</main>
	</body>
</html>
