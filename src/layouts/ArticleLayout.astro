---
const { frontmatter } = Astro.props;

const title = frontmatter.title ?? "游殿村故事";
const description = frontmatter.description ?? "游殿村故事文章";
const category = frontmatter.category ?? "游殿村故事";
const status = frontmatter.status ?? null;
const publishedDate = frontmatter.pubDate
	? new Intl.DateTimeFormat("zh-CN", { dateStyle: "long" }).format(
			new Date(frontmatter.pubDate),
		)
	: null;
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | 游殿村故事</title>
	</head>
	<body>
		<main class="article-shell">
			<nav class="article-nav" aria-label="文章导航">
				<a class="back-link" href={import.meta.env.BASE_URL}>← 返回首页</a>
				<a class="back-link" href={`${import.meta.env.BASE_URL}articles/`}>文章目录</a>
			</nav>
			<article>
				<header>
					<p class="eyebrow">{category}</p>
					<h1>{title}</h1>
					<div class="meta">
						{publishedDate && <span>{publishedDate}</span>}
						{status && <span>{status}</span>}
					</div>
					{description && <p class="description">{description}</p>}
				</header>
				<div class="content">
					{status === "待补充" && (
						<p class="empty-note">这篇文章的正文还在整理中，后续会继续补充。</p>
					)}
					<slot />
				</div>
			</article>
		</main>
	</body>
</html>

<style>
	:root {
		color: #172033;
		background: #fffaf0;
		font-family:
			Inter, "Noto Sans SC", "PingFang SC", "Microsoft YaHei", system-ui,
			sans-serif;
	}

	body {
		margin: 0;
		min-height: 100vh;
		background:
			radial-gradient(circle at top right, rgba(96, 165, 250, 0.2), transparent 30rem),
			linear-gradient(180deg, #fffaf0 0%, #f8fafc 100%);
	}

	.article-shell {
		box-sizing: border-box;
		width: min(100%, 50rem);
		margin: 0 auto;
		padding: 3rem 1.25rem 5rem;
	}

	.article-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.back-link {
		display: inline-flex;
		color: #b45309;
		font-weight: 700;
		text-decoration: none;
	}

	.back-link:hover,
	.back-link:focus-visible {
		text-decoration: underline;
	}

	article {
		padding: clamp(1.5rem, 5vw, 3rem);
		border: 1px solid rgba(23, 32, 51, 0.1);
		border-radius: 1.5rem;
		background: rgba(255, 255, 255, 0.82);
		box-shadow: 0 1rem 3rem rgba(23, 32, 51, 0.08);
	}

	header {
		padding-bottom: 2rem;
		border-bottom: 1px solid rgba(23, 32, 51, 0.1);
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		color: #b45309;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.2rem, 8vw, 4.5rem);
		line-height: 1.1;
	}

	.meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 1rem;
	}

	.meta span {
		padding: 0.25rem 0.65rem;
		border-radius: 999px;
		background: #fff7ed;
		color: #6b7280;
		font-size: 0.92rem;
		font-weight: 700;
	}

	.description {
		margin: 1.25rem 0 0;
		max-width: 38rem;
		color: #465367;
		font-size: 1.1rem;
		line-height: 1.8;
	}

	.content {
		margin-top: 2rem;
		color: #2f3a4c;
		font-size: 1.05rem;
		line-height: 1.85;
	}

	.empty-note {
		padding: 1rem 1.1rem;
		border: 1px dashed rgba(180, 83, 9, 0.35);
		border-radius: 1rem;
		background: #fff7ed;
		color: #9a3412;
	}

	.content :global(h2) {
		margin: 2rem 0 0.75rem;
		color: #172033;
		font-size: 1.5rem;
	}

	.content :global(p) {
		margin: 0 0 1.25rem;
	}

	.content :global(ul) {
		margin: 0 0 1.5rem;
		padding-left: 1.4rem;
	}

	.content :global(li + li) {
		margin-top: 0.5rem;
	}
</style>
