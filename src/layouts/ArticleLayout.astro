---
import "../styles/global.css";

const { frontmatter } = Astro.props;

const title = frontmatter.title ?? "游殿村故事";
const description = frontmatter.description ?? "游殿村故事文章";
const category = frontmatter.category ?? "游殿村故事";
const status = frontmatter.status ?? null;
const pageBackgroundClass =
	"min-h-screen bg-[radial-gradient(circle_at_top_left,rgba(66,184,131,0.12),transparent_30rem),linear-gradient(180deg,#fffaf0_0%,#f8f1e3_100%)] font-sans text-youdian-ink";
const backLinkClass =
	"inline-flex font-bold text-youdian-leaf-dark no-underline transition hover:text-youdian-ink focus-visible:text-youdian-ink";
const badgeClass =
	"status-badge font-bold text-gray-500";
const publishedDate = frontmatter.pubDate
	? new Intl.DateTimeFormat("zh-CN", { dateStyle: "long" }).format(
			new Date(frontmatter.pubDate),
		)
	: null;
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | 游殿村故事</title>
	</head>
	<body class={pageBackgroundClass}>
		<main class="mx-auto box-border w-full max-w-[52rem] px-5 pt-5 pb-16">
			<nav class="mb-10 flex flex-wrap justify-between gap-4 border-b border-youdian-ink/10 py-4" aria-label="文章导航">
				<a class={backLinkClass} href={import.meta.env.BASE_URL}>← 返回首页</a>
				<a class={backLinkClass} href={`${import.meta.env.BASE_URL}articles/`}>文章目录</a>
			</nav>
			<article class="overflow-hidden rounded-[1.6rem] border border-youdian-ink/10 bg-white/80 shadow-[0_1.5rem_4rem_rgba(23,32,51,0.08)]">
				<header class="border-b border-youdian-ink/10 bg-white/75 p-[clamp(1.5rem,5vw,3rem)]">
					<p class="mb-3 text-[0.8rem] font-bold uppercase tracking-[0.16em] text-youdian-leaf-dark">
						{category}
					</p>
					<h1 class="m-0 text-[clamp(2.15rem,8vw,4.3rem)] font-extrabold leading-[1.08] tracking-[-0.04em]">{title}</h1>
					<div class="mt-4 flex flex-wrap gap-2">
						{publishedDate && <span class={badgeClass}>{publishedDate}</span>}
						{status && <span class={badgeClass}>{status}</span>}
					</div>
					{description && (
						<p class="mt-5 max-w-[38rem] text-[1.1rem] leading-[1.8] text-youdian-muted">
							{description}
						</p>
					)}
				</header>
				<div class="prose px-[clamp(1.5rem,5vw,3rem)] pt-8 pb-[clamp(2rem,6vw,4rem)]">
					<slot />
				</div>
			</article>
		</main>
	</body>
</html>
