---
const { frontmatter } = Astro.props;

const title = frontmatter.title ?? 'Youdian';
const description = frontmatter.description ?? 'Youdian article';
const publishedDate = frontmatter.pubDate
	? new Intl.DateTimeFormat('zh-CN', { dateStyle: 'long' }).format(
			new Date(frontmatter.pubDate),
		)
	: null;
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Youdian</title>
	</head>
	<body>
		<main class="article-shell">
			<a class="back-link" href={import.meta.env.BASE_URL}>← 返回首页</a>
			<article>
				<header>
					<p class="eyebrow">Demo Article</p>
					<h1>{title}</h1>
					{publishedDate && <p class="date">{publishedDate}</p>}
					{description && <p class="description">{description}</p>}
				</header>
				<div class="content">
					<slot />
				</div>
			</article>
		</main>
	</body>
</html>

<style>
	:root {
		color: #172033;
		background: #fffaf0;
		font-family:
			Inter, "Noto Sans SC", "PingFang SC", "Microsoft YaHei", system-ui,
			sans-serif;
	}

	body {
		margin: 0;
		min-height: 100vh;
		background:
			radial-gradient(circle at top right, rgba(96, 165, 250, 0.2), transparent 30rem),
			linear-gradient(180deg, #fffaf0 0%, #f8fafc 100%);
	}

	.article-shell {
		box-sizing: border-box;
		width: min(100%, 50rem);
		margin: 0 auto;
		padding: 3rem 1.25rem 5rem;
	}

	.back-link {
		display: inline-flex;
		margin-bottom: 2rem;
		color: #b45309;
		font-weight: 700;
		text-decoration: none;
	}

	.back-link:hover,
	.back-link:focus-visible {
		text-decoration: underline;
	}

	article {
		padding: clamp(1.5rem, 5vw, 3rem);
		border: 1px solid rgba(23, 32, 51, 0.1);
		border-radius: 1.5rem;
		background: rgba(255, 255, 255, 0.82);
		box-shadow: 0 1rem 3rem rgba(23, 32, 51, 0.08);
	}

	header {
		padding-bottom: 2rem;
		border-bottom: 1px solid rgba(23, 32, 51, 0.1);
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		color: #b45309;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.2rem, 8vw, 4.5rem);
		line-height: 1.1;
	}

	.date {
		margin: 1rem 0 0;
		color: #6b7280;
	}

	.description {
		margin: 1.25rem 0 0;
		max-width: 38rem;
		color: #465367;
		font-size: 1.1rem;
		line-height: 1.8;
	}

	.content {
		margin-top: 2rem;
		color: #2f3a4c;
		font-size: 1.05rem;
		line-height: 1.85;
	}

	.content :global(h2) {
		margin: 2rem 0 0.75rem;
		color: #172033;
		font-size: 1.5rem;
	}

	.content :global(p) {
		margin: 0 0 1.25rem;
	}

	.content :global(ul) {
		margin: 0 0 1.5rem;
		padding-left: 1.4rem;
	}

	.content :global(li + li) {
		margin-top: 0.5rem;
	}
</style>
